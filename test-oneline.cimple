var age: number = 19;var name: string = "Landon";var favorite_letter = 'F';fun print(input: string): void {/* some kind of printing logic */}print(name);print(age);print(favorite_letter);if (number > 18) {print("Is an adult\n");}var n: number = 0;while (number < 10) {print("HI (while)");number += 1;}for (i: int = 0; i < 10; i++) {print("HI (for)")}
